      "Bash(ls:*)",
      "mcp__terraform__create_workspace",
      "mcp__terraform__get_workspace_details",
      "mcp__aws-knowledge-mcp-server__aws___search_documentation",
      "mcp__terraform__get_latest_provider_version",
      "mcp__aws-knowledge-mcp-server__aws___get_regional_availability",
      "mcp__aws-knowledge-mcp-server__aws___read_documentation",
      "Bash(terraform plan:*)",
      "Bash(terraform apply:*)",
      "Bash(.foundations/scripts/bash/update-agent-context.sh:*)",
      "Skill(tf-plan)",
      "Skill(tf-implement)",
      "Bash(cat:*)",
      "Bash(env)",
      "Bash(git log:*)",
      "Bash(echo:*)",
      "Skill(tf-e2e-tester)",

      "Skill(terraform-test)",
      "Skill(terraform-stacks)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(curl:*)",
      "mcp__terraform__update_workspace_variable",
      "mcp__terraform__list_workspace_variables",
      "Bash(docker build:*)",
      "Bash(docker images:*)",
      "Bash(.foundations/scripts/bash/validate-env.sh:*)",
      "WebFetch(domain:github.com)",
      "Bash(npx ccstatusline@latest:*)",
      "Bash(npm run health:*)",
      "WebFetch(domain:claude.com)",
      "Bash(python3:*)",
      "Bash(xargs sed:*)",
      "Bash(for f in .foundations/archive/tasks.md .foundations/archive/the_plan.md .foundations/design_resources/03-claude-code-plugins-ecosystem.md .foundations/design_resources/01-speckit-spec-driven-development.md)",
      "Bash(do sed -i '' 's|speckit\\\\.foundations|speckit.specify|g' \"$f\")",
      "Bash(done)",
      "Bash(wc:*)",
      "Bash(git ls-tree:*)",
      "Bash(bash:*)",
      "Bash(gh issue view:*)",
      "Bash(GH_HOST=github.ibm.com gh issue view:*)",
      "Bash(gh api:*)",
      "Bash(open:*)"
